<?xml version="1.0" encoding="UTF-8"?>
<!--
  Real-LRT-shaped fixture.

  Captured against LRTimelapse Pro 7.5.3 (Mac) output 2026-05-22. Carries
  the exact attributes a real LRT-written sidecar uses:
    - xmlns:lrt namespace is the bare http://lrtimelapse.com/
      (NOT http://lrtimelapse.com/ns/1.0/ as our earlier synthetic
      fixtures used)
    - the keyframe marker is xmp:Rating="4" (real LRT writes 4 on
      Creative keyframes; 0 on interpolated/normal frames)
    - the LR-default identity tone curve [(0,0), (255,255)] is
      written into every frame regardless of user edits
    - crs:Sharpness="25" is LR's out-of-camera default, also
      written into every frame regardless

  This fixture is the parser's contract against real LRT XMP. The
  earlier tests/fixtures/synthetic_*.xmp files use a different
  (incorrect) schema; they remain because the lrt:keyframe fallback
  path keeps them working.
-->
<x:xmpmeta xmlns:x="adobe:ns:meta/" x:xmptk="lrt-cinema synthetic fixture">
 <rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#">
  <rdf:Description rdf:about=""
    xmlns:crs="http://ns.adobe.com/camera-raw-settings/1.0/"
    xmlns:lrt="http://lrtimelapse.com/"
    xmlns:xmp="http://ns.adobe.com/xap/1.0/"
    crs:Exposure2012="-0.500000"
    crs:Contrast2012="0"
    crs:Highlights2012="0"
    crs:Shadows2012="0"
    crs:Whites2012="0"
    crs:Blacks2012="0"
    crs:Saturation="0"
    crs:Vibrance="0"
    crs:Sharpness="25"
    crs:WhiteBalance="As Shot"
    xmp:Rating="4">
   <crs:ToneCurvePV2012>
    <rdf:Seq>
     <rdf:li>0, 0</rdf:li>
     <rdf:li>255, 255</rdf:li>
    </rdf:Seq>
   </crs:ToneCurvePV2012>
  </rdf:Description>
 </rdf:RDF>
</x:xmpmeta>
